// Customer Insight Analytics — Prisma schema
// PostgreSQL. Minimal V1 models for a rule-based insight engine + optional batch AI.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Shopify offline/online session storage (required shape for
/// @shopify/shopify-app-session-storage-prisma v9). Do not rename fields.
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop])
}

/// One row per installed shop. The hub all app data hangs off.
model Shop {
  id            String    @id @default(cuid())
  shopDomain    String    @unique
  plan          String    @default("free") // free | starter | growth | pro
  installedAt   DateTime  @default(now())
  uninstalledAt DateTime?
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages         ImportedMessage[]
  runs             InsightRun[]
  reports          WeeklyReport[]
  settings         AppSetting[]
  usage            UsageCounter[]
  shopifyProducts  ShopifyProduct[]
  shopifyOrders    ShopifyOrder[]
  shopifyCustomers ShopifyCustomer[]
  generatedFaqs    GeneratedFaq[]
  weeklyEmails     WeeklyEmail[]
  publishedContents    PublishedContent[]
  competitors          Competitor[]
  bulkJobs             BulkJob[]
  emailReportLogs      EmailReportLog[]
  productOptDrafts     ProductOptimizationDraft[]
  copilotMessages      CopilotMessage[]
  contentLibraryItems  ContentLibraryItem[]
  revenueEvents        RevenueEvent[]
  autoPublishRules     AutoPublishRule[]
  marketingAssets      MarketingAsset[]

  @@index([shopDomain])
}

/// A single unit of customer "voice" the engine analyzes: an order note,
/// a customer email, a product text blob, or an imported conversation line.
model ImportedMessage {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  source      String // order_note | customer_email | product_text | csv | manual
  externalId  String? // e.g. shopify order/customer id
  customerRef String? // hashed email or customer id (never store raw PII when avoidable)
  content     String
  rawMeta     String? // JSON string with extra context
  occurredAt  DateTime // event time, used for trend windows
  createdAt   DateTime @default(now())

  @@unique([shopId, externalId])
  @@index([shopId, occurredAt])
  @@index([shopId, source])
}

/// One analysis pass. Holds a JSON snapshot plus normalized child findings.
model InsightRun {
  id           String    @id @default(cuid())
  shopId       String
  shop         Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  status        String    @default("completed") // running | completed | failed
  messageCount  Int       @default(0)
  productCount  Int       @default(0)
  insightScore  Int       @default(0)
  windowDays   Int       @default(30)
  summaryJson  String? // full InsightResult JSON snapshot
  error        String?
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  keywordFindings  KeywordFinding[]
  productFindings  ProductFinding[]
  faqOpportunities FaqOpportunity[]

  @@index([shopId, createdAt])
}

/// Aggregated frequency + trend for a keyword group within a run.
model KeywordFinding {
  id           String     @id @default(cuid())
  runId        String
  run          InsightRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  shopId       String
  groupId      String // shipping | return | refund | ...
  keyword      String // representative keyword/phrase
  count        Int        @default(0)
  prev7Count   Int        @default(0)
  prev30Count  Int        @default(0)
  trend7       Float      @default(0) // pct change vs previous 7d window
  trend30      Float      @default(0) // pct change vs previous 30d window
  exampleQuote String?
  createdAt    DateTime   @default(now())

  @@index([runId, groupId])
  @@index([shopId, groupId])
}

/// Products that customers are most confused about within a run.
model ProductFinding {
  id             String     @id @default(cuid())
  runId          String
  run            InsightRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  shopId         String
  productId      String? // shopify gid or null when unmatched
  productTitle   String
  mentionCount   Int        @default(0)
  confusionScore Float      @default(0)
  topGroups      String? // JSON array of groupIds
  exampleQuote   String?
  createdAt      DateTime   @default(now())

  @@index([runId])
  @@index([shopId])
}

/// A suggested FAQ entry the store is "missing": a topic asked about a lot
/// but not covered by existing product/page content.
model FaqOpportunity {
  id         String     @id @default(cuid())
  runId      String
  run        InsightRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  shopId     String
  groupId    String
  question   String
  rationale  String?
  frequency  Int        @default(0)
  hasContent Boolean    @default(false)
  priority   Int        @default(0)
  productId  String?
  createdAt  DateTime   @default(now())

  @@index([runId])
  @@index([shopId, groupId])
}

/// A rendered weekly report. aiSummary is null unless a merchant generated one.
model WeeklyReport {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  runId        String?
  weekStart    DateTime
  weekEnd      DateTime
  insightScore Int      @default(0)
  dataJson     String // JSON snapshot used to render the report
  aiSummary    String? // optional batch-generated narrative
  aiProvider   String? // mock | groq | gemini
  generatedAt  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([shopId, weekStart])
}

/// Arbitrary per-shop key/value settings (AI provider toggle, competitor list, etc.).
model AppSetting {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  key       String
  value     String // JSON-encoded or scalar
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, key])
}

/// Usage metering for plan gating. One row per (shop, metric, period bucket).
model UsageCounter {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  period    String // "2026-06" (month) or "2026-W23" (iso week)
  metric    String // messages | analyses | ai_summaries
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, metric, period])
  @@index([shopId])
}

/// Shopify product snapshot used for local analysis and product confusion detail.
model ShopifyProduct {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  externalId  String
  title       String
  handle      String?
  description String?
  vendor      String?
  tags        String?
  productType String?
  collections String?
  shopifyUpdatedAt DateTime?
  rawJson     String?
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, externalId])
  @@index([shopId, title])
}

/// Shopify order snapshot. Notes become analyzable ImportedMessages.
model ShopifyOrder {
  id          String    @id @default(cuid())
  shopId      String
  shop        Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  externalId  String
  name        String?
  note        String?
  customerRef String?
  tags        String?
  processedAt DateTime?
  rawJson     String?
  syncedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([shopId, externalId])
  @@index([shopId, processedAt])
}

/// Shopify customer snapshot. Tags and notes can surface purchase-friction topics.
model ShopifyCustomer {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  externalId  String
  displayName String?
  emailHash   String?
  tags        String?
  note        String?
  rawJson     String?
  syncedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([shopId, externalId])
  @@index([shopId])
}

/// A FAQ entry generated by the app (rule-based SEO or AI) for a topic/product.
/// "Save to Shopify" stores it here; publishing pushes the HTML to a product.
model GeneratedFaq {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  groupId       String? // friction group this FAQ addresses
  productId     String? // shopify gid when targeted at a product
  productTitle  String?
  question      String
  answerText    String
  answerHtml    String
  format        String    @default("seo") // seo | ai | plain
  source        String    @default("rule") // rule | ai
  status        String    @default("draft") // draft | prepared | published | failed | rolled_back
  publishTarget String    @default("metafield") // metafield | append_description | faq_block
  publishRef    String?
  previousHtml  String?
  error         String?
  publishedAt   DateTime?
  rolledBackAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId, status])
  @@index([shopId, productId])
}

/// Merchant-configured competitor brands tracked across analysis runs.
/// intentTypes tracked: comparison | switching | price | feature | trust | general
model Competitor {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  domain    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mentions      CompetitorMention[]
  opportunities CompetitorOpportunity[]

  @@unique([shopId, name])
  @@index([shopId])
}

/// Individual competitor mention classified by intent from an imported message.
model CompetitorMention {
  id           String     @id @default(cuid())
  shopId       String
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  messageId    String?
  intentType   String     @default("general") // comparison | switching | price | feature | trust | general
  quote        String?
  occurredAt   DateTime
  createdAt    DateTime   @default(now())

  @@index([shopId, competitorId])
  @@index([shopId, occurredAt])
}

/// Aggregated revenue opportunity derived from competitor mentions.
model CompetitorOpportunity {
  id                String     @id @default(cuid())
  shopId            String
  competitorId      String
  competitor        Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  opportunityType   String     // comparison_content | why_us_page | competitor_landing | price_objection
  estimatedRevenue  Float      @default(0)
  affectedCustomers Int        @default(0)
  mentionCount      Int        @default(0)
  growthRate        Float      @default(0)
  status            String     @default("open") // open | actioned | dismissed
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([shopId, competitorId])
  @@index([shopId, status])
}

/// Tracks every page, blog article, or other asset published to Shopify by this app.
/// contentType: faq_page | shipping_page | return_page | warranty_page | payment_page | discount_page | blog_article
/// status: published | failed | deleted
model PublishedContent {
  id            String    @id @default(cuid())
  shopId        String
  shop          Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  contentType   String
  resourceId    String?   // Shopify GID returned after creation
  resourceTitle String
  sourceId      String?   // GeneratedFaq.id when re-publishing a saved FAQ
  status        String    @default("published")
  error         String?
  publishedAt   DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shopId, contentType])
  @@index([shopId, publishedAt])
}

/// Bulk processing job: generate, publish, export, or ignore a batch of opportunities.
/// status: queued | running | completed | failed
model BulkJob {
  id             String        @id @default(cuid())
  shopId         String
  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  jobType        String        // generate | publish_pages | publish_blogs | publish_product_faqs | export | ignore
  status         String        @default("queued")
  filterType     String?       // storewide | product | competitor | high_impact | not_published
  totalItems     Int           @default(0)
  processedItems Int           @default(0)
  failedItems    Int           @default(0)
  resultJson     String?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items BulkJobItem[]

  @@index([shopId, status])
  @@index([shopId, createdAt])
}

/// Individual item within a BulkJob. Supports per-item retry.
model BulkJobItem {
  id         String   @id @default(cuid())
  jobId      String
  job        BulkJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  itemId     String
  itemType   String   // opportunity | faq | product
  status     String   @default("queued") // queued | running | completed | failed
  retryCount Int      @default(0)
  result     String?
  error      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([jobId, status])
}

/// Log of every email report attempt: weekly, monthly, alerts, and test sends.
/// Delivery is provider-agnostic; mock provider logs here without actual sending.
model EmailReportLog {
  id             String    @id @default(cuid())
  shopId         String
  shop           Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  reportType     String    // weekly | monthly | quarterly | alert_competitor | alert_high_impact | test
  subject        String
  recipientEmail String
  status         String    @default("pending") // pending | sent | failed | skipped
  provider       String    @default("mock")    // mock | sendgrid | postmark | resend
  error          String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([shopId, createdAt])
  @@index([shopId, reportType])
}

/// AI or rule-based optimisation draft for one section of a Shopify product.
/// sectionType: description | seo_title | meta_description | benefits |
///   objection_handling | comparison | trust | warranty | shipping | return
model ProductOptimizationDraft {
  id              String    @id @default(cuid())
  shopId          String
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  productId       String
  productTitle    String
  sectionType     String
  originalContent String?
  draftContent    String
  draftHtml       String
  source          String    @default("rule") // rule | ai
  status          String    @default("draft") // draft | published | rolled_back
  publishedAt     DateTime?
  rolledBackAt    DateTime?
  error           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([shopId, productId])
  @@index([shopId, status])
}

/// Phase 12 — AI Revenue Copilot message log.
/// role: user | assistant
model CopilotMessage {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  role       String   // user | assistant
  content    String
  context    String?  // JSON insight snapshot used for this response
  sessionRef String?  // client-generated session grouping key
  topic      String?  // detected topic: shipping | returns | competitors | revenue | content | faq | analytics | general
  confidence Int      @default(0) // 0-100 response confidence
  createdAt  DateTime @default(now())

  @@index([shopId, createdAt])
  @@index([shopId, sessionRef])
}

/// Phase 12 — Recovery Content Library item.
/// itemType: faq | blog_tip | page_template | email_snippet | social_post
model ContentLibraryItem {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  itemType   String   // faq | blog_tip | page_template | email_snippet | social_post
  title      String
  content    String
  tags       String?  // JSON array of tag strings
  groupId    String?  // friction group reference
  productId  String?  // shopify product gid
  source     String   @default("generated") // generated | manual | imported
  status     String   @default("active")    // active | archived
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId, itemType])
  @@index([shopId, status])
  @@index([shopId, groupId])
}

/// Phase 12 — Revenue recovery timeline event.
/// eventType: content_published | faq_created | insight_run | competitor_resolved | bulk_job
model RevenueEvent {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  eventType    String   // content_published | faq_created | insight_run | competitor_resolved | bulk_job | manual
  description  String
  refId        String?  // source record id
  refType      String?  // published_content | generated_faq | bulk_job
  lowEstimate  Float    @default(0)
  highEstimate Float    @default(0)
  actualValue  Float?   // manually confirmed actual recovery
  occurredAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([shopId, occurredAt])
  @@index([shopId, eventType])
}

/// Phase 12 — Auto-publish rule configuration.
/// ruleType: faq | blog | page
model AutoPublishRule {
  id         String    @id @default(cuid())
  shopId     String
  shop       Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  ruleType   String    // faq | blog | page
  trigger    String    // on_insight | on_threshold | manual
  conditions String?   // JSON: { minSeverity, minMentions, groupIds, maxPerRun }
  enabled    Boolean   @default(false)
  lastRunAt  DateTime?
  totalRuns  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([shopId, ruleType])
  @@index([shopId, enabled])
}

/// Phase 12 — Marketing asset generated for store promotion.
/// assetType: social_post | email_subject | ad_copy | review_request | sms_snippet
model MarketingAsset {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  assetType  String   // social_post | email_subject | ad_copy | review_request | sms_snippet
  platform   String   // instagram | facebook | email | google_ads | sms | generic
  content    String
  headline   String?
  cta        String?
  productId  String?
  groupId    String?
  tone       String   @default("professional") // professional | friendly | urgent | empathetic
  status     String   @default("draft")        // draft | used | archived
  usageCount Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shopId, assetType])
  @@index([shopId, platform])
  @@index([shopId, status])
}

/// Stored weekly recovery email HTML. Provider delivery is intentionally out of scope.
model WeeklyEmail {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  runId       String?
  subject     String
  html        String
  status      String   @default("generated") // generated | previewed
  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([shopId, generatedAt])
}
